@model IEnumerable<LMS.Models.ViewModels.PendingAssignmentViewModel>

@{
    ViewData["Title"] = "Pending Assignments";
}
@* 
<div class="text-center mb-4">
    <img src="~/images/logo.png" width="80" />
    <h3 class="fw-bold">Instructor Panel</h3>
</div> *@
<h2 class="mb-4 fw-bold">
    <i class="bi bi-hourglass-split text-warning"></i> Pending Assignments
</h2>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Success',
            text: '@TempData["Success"]'
        });
    </script>
}

<div class="card shadow">
    <div class="card-body">

        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th><i class="bi bi-person"></i> Student</th>
                    <th><i class="bi bi-journal-text"></i> Assignment</th>
                    <th><i class="bi bi-book"></i> Course</th>
                    <th><i class="bi bi-star"></i> Marks</th>
                    <th><i class="bi bi-calendar"></i> Submitted Date</th>
                    <th><i class="bi bi-info-circle"></i> Status</th>
                    <th><i class="bi bi-gear"></i> Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.StudentName</td>
                        <td>@item.AssignmentTitle</td>
                        <td>@item.CourseTitle</td>

                        <td>
                            <span class="badge bg-info">
                                @item.EarnedMark / @item.AssignmentMark
                            </span>
                        </td>
                        @* submittion Date *@
                        <td>
                            @* <i class="bi bi-calendar"></i> *@
                            @item.SubmittedDate?.ToString("dd MMM yyyy")
                        </td>

                        <td>
                            @if(@item.Status==1)
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else if(@item.Status==2)
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Pending</span>
                            }
                        </td>

                        <td>

                            <!-- VIEW -->
                            <a asp-action="AssignmentDetails" asp-route-id="@item.AssignmentId"
                               class="btn btn-primary btn-sm">
                                View
                            </a>

                            <!-- APPROVE -->
                            <button class="btn btn-success btn-sm approve-btn"
                                    data-studentid="@item.StudentId"
                                    data-assignmentid="@item.AssignmentId"
                                    @(item.Status == 2 || item.Status == 1 ? "disabled" : "")>
                                Approve
                            </button>

                            <!-- REJECT -->
                            <form asp-action="Reject" method="post" style="display:inline">
                                <input type="hidden" name="studentId" value="@item.StudentId" />
                                <input type="hidden" name="assignmentId" value="@item.AssignmentId" />

                                <button class="btn btn-danger btn-sm"
                                        @(item.Status == 2 || item.Status == 1 ? "disabled" : "")>
                                    Reject
                                </button>
                            </form>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <!-- BACK BUTTON -->
        <div class="mt-4 text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>
</div>

