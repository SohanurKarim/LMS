@model LMS.Models.Course

@{
    ViewData["Title"] = "Edit Course";
}

<h2 class="mb-4 fw-bold">
    <i class="bi bi-pencil-square text-primary"></i> Edit Course
</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <form asp-action="Edit" method="post">

            <!-- Hidden ID -->
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="InstructorId" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- TITLE -->
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold">
                    <i class="bi bi-book"></i> Course Title
                </label>
                <input asp-for="Title" class="form-control" placeholder="Enter course title" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">
                    <i class="bi bi-card-text"></i> Description
                </label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Enter course description"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- ROW -->
            <div class="row">

                <!-- CREDITS -->
                <div class="col-md-6 mb-3">
                    <label asp-for="Credits" class="form-label fw-semibold">
                        <i class="bi bi-award"></i> Credits
                    </label>
                    <input asp-for="Credits" class="form-control" />
                    <span asp-validation-for="Credits" class="text-danger"></span>
                </div>

                <!-- MAX ENROLLMENT -->
                <div class="col-md-6 mb-3">
                    <label asp-for="MaxEnrollment" class="form-label fw-semibold">
                        <i class="bi bi-people"></i> Max Enrollment
                    </label>
                    <input asp-for="MaxEnrollment" class="form-control" />
                    <span asp-validation-for="MaxEnrollment" class="text-danger"></span>
                </div>

            </div>

            <!-- ROW -->
            <div class="row">

                <!-- START DATE -->
                <div class="col-md-6 mb-3">
                    <label asp-for="StartDate" class="form-label fw-semibold">
                        <i class="bi bi-calendar-check"></i> Start Date
                    </label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <!-- END DATE -->
                <div class="col-md-6 mb-3">
                    <label asp-for="EndDate" class="form-label fw-semibold">
                        <i class="bi bi-calendar-x"></i> End Date
                    </label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

            </div>

            <!-- BUTTONS -->
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success rounded-pill">
                    <i class="bi bi-check-circle"></i> Update
                </button>

                <a asp-action="Index" class="btn btn-secondary rounded-pill">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}