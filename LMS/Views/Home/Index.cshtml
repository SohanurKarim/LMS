                    </div>
                </div>
            </div>

            <!-- CARD 3 -->
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0 h-100">

                    <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c"
                         class="card-img-top" />

                    <div class="card-body">

                        <h5 class="fw-bold">Flutter Development</h5>
                        <p class="text-muted">
                            Build Android & iOS apps with Flutter & Dart.
                        </p>

                        <div class="mb-2 text-warning">⭐⭐⭐⭐⭐</div>

                        <a href="#" class="btn btn-outline-primary rounded-pill w-100">
                            View Course
                        </a>

                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ================= STUDENT REVIEWS ================= -->
