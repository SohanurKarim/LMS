@model LMS.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<h2 class="mb-4 fw-bold text-danger">
    <i class="bi bi-exclamation-triangle-fill"></i> Delete Course
</h2>

<div class="card shadow-sm border-danger">
    <div class="card-body">

        <!-- WARNING MESSAGE -->
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Warning!</strong>&nbsp;This action cannot be undone.
        </div>

        <!-- COURSE DETAILS -->
        <dl class="row">

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-book"></i> Title
            </dt>
            <dd class="col-sm-9 text-primary fw-semibold">
                @Model.Title
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-card-text"></i> Description
            </dt>
            <dd class="col-sm-9">
                @Model.Description
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-person-badge"></i> Instructor
            </dt>
            <dd class="col-sm-9">
                <span class="badge bg-secondary">
                    @Model.InstructorId
                </span>
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-award"></i> Credits
            </dt>
            <dd class="col-sm-9">
                <span class="badge bg-info text-dark">@Model.Credits</span>
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-people"></i> Max Enrollment
            </dt>
            <dd class="col-sm-9">
                <span class="badge bg-warning text-dark">@Model.MaxEnrollment</span>
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-calendar-check"></i> Start Date
            </dt>
            <dd class="col-sm-9">
                @Model.StartDate.ToString("dd MMM yyyy")
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-calendar-x"></i> End Date
            </dt>
            <dd class="col-sm-9">
                @Model.EndDate.ToString("dd MMM yyyy")
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-calendar-plus"></i> Created Date
            </dt>
            <dd class="col-sm-9">
                @Model.CreatedDate.ToString("dd MMM yyyy")
            </dd>

        </dl>

        <!-- ACTION BUTTONS -->
        <form asp-action="Delete" class="mt-4 d-flex gap-2">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger rounded-pill">
                <i class="bi bi-trash"></i> Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary rounded-pill">
                <i class="bi bi-arrow-left"></i> Cancel
            </a>
        </form>

    </div>
</div>