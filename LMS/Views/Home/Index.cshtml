                    <h6 class="fw-bold">Rahim Ahmed</h6>
                    <p class="text-warning">⭐⭐⭐⭐⭐</p>

                    <p class="text-muted">
                        "This LMS helped me get my first job as a developer!"
                    </p>

                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0 p-3">

                    <img src="https://i.pravatar.cc/100?img=2"
                         class="rounded-circle mx-auto mb-2" />

                    <h6 class="fw-bold">Nusrat Jahan</h6>
                    <p class="text-warning">⭐⭐⭐⭐⭐</p>

                    <p class="text-muted">
                        "Courses are very practical and easy to understand."
                    </p>

                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0 p-3">

                    <img src="https://i.pravatar.cc/100?img=3"
                         class="rounded-circle mx-auto mb-2" />

                    <h6 class="fw-bold">Sakib Hasan</h6>
                    <p class="text-warning">⭐⭐⭐⭐⭐</p>

                    <p class="text-muted">
                        "Best LMS platform I have ever used in Bangladesh."
                    </p>

                </div>
            </div>

        </div>
    </div>
</section>

<!-- ================= OFFER BANNER ================= -->
<section class="py-5 text-white text-center"
         style="background: linear-gradient(135deg,#198754,#20c997);">

    <div class="container">

        <h2 class="fw-bold">🎉 Special Discount</h2>
        <p>Get up to 60% OFF on all courses for limited time</p>

        <a href="#" class="btn btn-light btn-lg rounded-pill">
            Grab Offer
        </a>

    </div>
</section>

<!-- ================= FOOTER CTA ================= -->
<section class="py-5 text-center">

    <div class="container">

        <h2 class="fw-bold">Start Your Learning Journey Today</h2>
        <p class="text-muted">Join thousands of learners and upgrade your career</p>
        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Instructor"))
        {
            <a asp-controller="Dashboard" asp-action="Instructor"
               class="btn btn-primary btn-lg rounded-pill">
                Get Started
            </a>
        }else if (SignInManager.IsSignedIn(User) && User.IsInRole("Student"))
        {
            <a asp-controller="Dashboard" asp-action="Student"
               class="btn btn-primary btn-lg rounded-pill">
                Get Started
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register"
               class="btn btn-primary rounded-pill">
                Get Started
            </a>
        }


    </div>

</section>