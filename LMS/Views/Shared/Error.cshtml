@model ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">

    <div class="card shadow-lg text-center p-4" style="max-width:600px; width:100%;">

        <!-- ICON -->
        <div class="mb-3">
            <i class="bi bi-exclamation-octagon-fill text-danger" style="font-size:70px;"></i>
        </div>

        <!-- TITLE -->
        <h2 class="text-danger fw-bold">Oops! Something went wrong</h2>

        <!-- MESSAGE -->
        <p class="text-muted">
            An unexpected error occurred while processing your request.
            Please try again or contact support if the problem persists.
        </p>

        <!-- REQUEST ID -->
        @if (Model.ShowRequestId)
        {
            <div class="alert alert-light border mt-3">
                <strong>Request ID:</strong>
                <code>@Model.RequestId</code>
            </div>
        }

        <!-- BUTTONS -->
        <div class="mt-4 d-flex justify-content-center gap-2">

            <a asp-controller="Home" asp-action="Index"
               class="btn btn-primary rounded-pill">
                <i class="bi bi-house"></i> Home
            </a>

            <a href="javascript:location.reload()"
               class="btn btn-warning rounded-pill">
                <i class="bi bi-arrow-repeat"></i> Retry
            </a>

            <a href="javascript:history.back()"
               class="btn btn-secondary rounded-pill">
                <i class="bi bi-arrow-left"></i> Back
            </a>

        </div>

    </div>

</div>

<!-- DEV INFO (OPTIONAL) -->
@if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
{
    <div class="container mt-4">
        <div class="alert alert-danger">
            <h5>Development Mode</h5>
            <p>
                Detailed error information is shown only in Development environment.
                Disable it in production for security.
            </p>
        </div>
    </div>
}