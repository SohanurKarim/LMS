@model IEnumerable<LMS.Models.Course>

@{
    ViewData["Title"] = "Active Courses";
}

<h2 class="mb-4 fw-bold">
    <i class="bi bi-journal-bookmark-fill text-primary"></i> Active Courses
</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="mb-3">
            <a class="btn btn-primary rounded-pill" asp-action="Create">
                <i class="bi bi-plus-circle"></i> Create Course
            </a>
        </div>

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th><i class="bi bi-book"></i> Title</th>
                    <th><i class="bi bi-card-text"></i> Description</th>
                    <th><i class="bi bi-person-badge"></i> Instructor</th>
                    <th><i class="bi bi-award"></i> Credits</th>
                    <th><i class="bi bi-people"></i> Max</th>
                    <th><i class="bi bi-calendar-event"></i> Start</th>
                    <th><i class="bi bi-calendar-x"></i> End</th>
                    <th><i class="bi bi-activity"></i> Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.EndDate < DateTime.Now ? "table-light" : "")">

                        <td class="fw-semibold text-primary">
                            @item.Title
                        </td>

                        <td>
                            @item.Description
                        </td>

                        <td>
                            <span class="badge bg-secondary">
                                <i class="bi bi-person"></i> @(item.Instructor?.UserName ?? "N/A")
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-info text-dark">
                                @item.Credits
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-warning text-dark">
                                @item.MaxEnrollment
                            </span>
                        </td>

                        <td>
                            <i class="bi bi-calendar-check text-success"></i>
                            @item.StartDate.ToString("dd MMM yyyy")
                        </td>

                        <td>
                            <i class="bi bi-calendar-x text-danger"></i>
                            @item.EndDate.ToString("dd MMM yyyy")
                        </td>

                        <td>
                            @if (item.EndDate >= DateTime.Now)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle"></i> Inactive
                                </span>
                            }
                        </td>

                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-exclamation-circle"></i> No courses found
            </div>
        }
        <!-- BACK BUTTON -->
        <div class="mt-4 text-end">
            <a asp-controller="Dashboard" asp-action="Instructor" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>
</div>