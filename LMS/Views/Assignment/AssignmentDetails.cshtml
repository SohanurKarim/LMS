@using LMS.Models.Enums
@model LMS.Models.StudentAssignment

@{
    ViewData["Title"] = "Assignment Details";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="text-center mb-4">
        <i class="bi bi-journal-text display-4 text-primary"></i>
        <h2 class="fw-bold mt-2">Assignment Details</h2>
        <p class="text-muted">Instructor Review Panel</p>
    </div>

    <!-- CARD -->
    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-dark text-white">
            <i class="bi bi-info-circle"></i> Submission Overview
        </div>

        <div class="card-body">

            <div class="row g-4">

                <!-- STUDENT -->
                <div class="col-md-6">
                    <div class="p-3 border rounded-3">
                        <h6 class="text-muted">
                            <i class="bi bi-person-circle"></i> Student
                        </h6>
                        <h5 class="fw-bold text-primary">
                            @Model.Student.Name
                        </h5>
                    </div>
                </div>

                <!-- COURSE -->
                <div class="col-md-6">
                    <div class="p-3 border rounded-3">
                        <h6 class="text-muted">
                            <i class="bi bi-book"></i> Course
                        </h6>
                        <h5 class="fw-bold">
                            @Model.Assignment.Course.Title
                        </h5>
                    </div>
                </div>

                <!-- ASSIGNMENT -->
                <div class="col-md-6">
                    <div class="p-3 border rounded-3">
                        <h6 class="text-muted">
                            <i class="bi bi-journal-text"></i> Assignment
                        </h6>
                        <h5 class="fw-bold">
                            @Model.Assignment.Title
                        </h5>
                    </div>
                </div>

                <!-- STATUS -->
                <div class="col-md-6">
                    <div class="p-3 border rounded-3">
                        <h6 class="text-muted">
                            <i class="bi bi-activity"></i> Status
                        </h6>

                        @if (Model.Status == AssignmentStatus.Approved)
                        {
                            <span class="badge bg-success fs-6">Approved</span>
                        }
                        else if (Model.Status == AssignmentStatus.Rejected)
                        {
                            <span class="badge bg-danger fs-6">Rejected</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark fs-6">Pending</span>
                        }
                    </div>
                </div>

                <!-- MARKS -->
                <div class="col-md-6">
                    <div class="p-3 border rounded-3">
                        <h6 class="text-muted">
                            <i class="bi bi-star"></i> Marks
                        </h6>

                        <h5>
                            <span class="text-success">
                                @Model.PointsEarned
                            </span>
                            /
                            <span class="text-secondary">
                                @Model.Assignment.MaxPoints
                            </span>
                        </h5>
                    </div>
                </div>

                <!-- SUBMITTED DATE -->
                <div class="col-md-6">
                    <div class="p-3 border rounded-3">
                        <h6 class="text-muted">
                            <i class="bi bi-calendar"></i> Submitted Date
                        </h6>
                        <h5>
                            @Model.SubmissionDate?.ToString("dd MMM yyyy")
                        </h5>
                    </div>
                </div>

                <!-- FEEDBACK -->
                <div class="col-12">
                    <div class="p-3 border rounded-3">
                        <h6 class="text-muted">
                            <i class="bi bi-chat-left-text"></i> Feedback
                        </h6>

                        @if (!string.IsNullOrEmpty(Model.Feedback))
                        {
                            <p class="mb-0">@Model.Feedback</p>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No feedback yet</p>
                        }
                    </div>
                </div>

            </div>

            <!-- BACK BUTTON -->
            <div class="mt-4 text-end">
                <a asp-action="PendingAssignments" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

        </div>
    </div>
</div>