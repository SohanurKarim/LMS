@using Microsoft.AspNetCore.Identity
@inject UserManager<User> userManager
@inject SignInManager<User> SignInManager
@{
    ViewData["Title"] = "Home";
}

<!-- ================= HERO SECTION ================= -->
<section class="py-5 text-white"
         style="
            background: url('https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=1920&q=80')
            center center / cover no-repeat;
            position: relative;
         ">

    <!-- DARK OVERLAY -->
    <div style="position:absolute; inset:0; background:rgba(0,0,0,0.6);"></div>

    <div class="container position-relative">

        <div class="row align-items-center justify-content-center text-center">

            <div class="col-md-10 col-lg-8">

                <!-- BADGE -->
                <span class="badge bg-light text-dark px-3 py-2 rounded-pill mb-3 shadow-sm">
                    🚀 Modern Learning Platform
                </span>

                <!-- TITLE -->
                <h1 class="fw-bold display-5 mb-3">
                    Upgrade Your Skills & Build a Successful Career
                </h1>

                <!-- SUBTITLE -->
                <p class="lead opacity-75 mb-4">
                    Learn in-demand skills, complete real-world projects, and become job-ready with our professional LMS platform designed for students and developers.
                </p>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    @* role wise button show hide *@
                    @if(SignInManager.IsSignedIn(User) && User.IsInRole("Instructor"))
                    {
                        <a asp-controller="Course" asp-action="Index"
                           class="btn btn-light btn-lg rounded-pill px-4 shadow-sm">
                            🎓 Explore Courses
                        </a>
                    }
                    else if(SignInManager.IsSignedIn(User) && User.IsInRole("Student"))
                    {
                        <a asp-controller="Course" asp-action="CourseDetails"
                           class="btn btn-light btn-lg rounded-pill px-4 shadow-sm">
                            🎓 Explore Courses
                        </a>
                    }else{
                        <a asp-controller="Account" asp-action="Login"
                           class="btn btn-light btn-lg rounded-pill px-4 shadow-sm">
                            🎓 Explore Courses
                    </a>
                    }
                    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Instructor"))
                    {
                        <a asp-controller="Dashboard" asp-action="Instructor"
                           class="btn btn-outline-light btn-lg rounded-pill px-4">
                            ✨ Get Started Free
                        </a>
                    }else if (SignInManager.IsSignedIn(User) && User.IsInRole("Student"))
                    {
                        <a asp-controller="Dashboard" asp-action="Student"
                           class="btn btn-outline-light btn-lg rounded-pill px-4">
                            ✨ Get Started Free
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Register"
                           class="btn btn-outline-light btn-lg rounded-pill px-4">
                            ✨ Get Started Free
                        </a>
                    }

                </div>

                <!-- STATS -->
                <div class="mt-4 d-flex justify-content-center gap-4 flex-wrap">

                    <div class="text-center">
                        <h5 class="fw-bold mb-0">50+</h5>
                        <small class="opacity-75">Courses</small>
                    </div>

                    <div class="text-center">
                        <h5 class="fw-bold mb-0">1K+</h5>
                        <small class="opacity-75">Students</small>
                    </div>

                    <div class="text-center">
                        <h5 class="fw-bold mb-0">4.8★</h5>
                        <small class="opacity-75">Rating</small>
                    </div>

                </div>

            </div>

        </div>

    </div>
</section>
