@using Microsoft.AspNetCore.Identity
@inject UserManager<User> userManager  // Here we inject the UserManager to get the user's information, such as their name, to display in the navbar
@inject SignInManager<User> SignInManager // Here we inject the SignInManager to check if the user is signed in

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LMS.styles.css" asp-append-version="true" />
    @* here use fontawsome *@
    <!-- Font Awesome Free CSS -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-3">
            <div class="container-fluid">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-mortarboard-fill text-warning"></i> LMS
                </a>

                <!-- TOGGLER -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- MENU -->
                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <!-- DASHBOARD -->
                            <li class="nav-item">
                                @if (User.IsInRole("Instructor"))
                                {
                                    <a class="nav-link" asp-controller="Dashboard" asp-action="Instructor">
                                        <i class="bi bi-speedometer2"></i> Dashboard
                                    </a>
                                }
                                else if (User.IsInRole("Student"))
                                {
                                    <a class="nav-link" asp-controller="Dashboard" asp-action="Student">
                                        <i class="bi bi-speedometer2"></i> Dashboard
                                    </a>
                                }
                            </li>

                            @if (User.IsInRole("Instructor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Course" asp-action="Index">
                                        <i class="bi bi-book"></i> Courses
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Enrollment" asp-action="Index">
                                        <i class="bi bi-people"></i> Enrollments
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Assignment" asp-action="Index">
                                        <i class="bi bi-journal-check"></i> Assignments
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Courses" asp-action="Index">
                                        <i class="bi bi-book"></i> Courses
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Assignments" asp-action="Index">
                                        <i class="bi bi-journal-check"></i> Assignments
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house"></i> Home
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Courses">
                                    <i class="bi bi-book"></i> Courses
                                </a>
                            </li>
                        }

                    </ul>

                    <!-- RIGHT SIDE LOGIN -->
                    <partial name="_LoginPartial" />

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="text-white pt-5 pb-3"
            style="background: #0f172a;">

        <div class="container">

            <div class="row">

                <!-- LOGO + ABOUT -->
                <div class="col-md-4 mb-4">

                    <div class="d-flex align-items-center mb-3">
                        @* <img src="~/images/logo.png" width="40" height="40" class="me-2" /> *@
                        <h5 class="fw-bold mb-0"><i class="bi bi-mortarboard-fill text-warning"></i> LMS Platform</h5>
                    </div>

                    <p class="text-muted">
                        A modern learning management system where students can learn skills, complete assignments, and build their career.
                    </p>

                </div>

                <!-- QUICK LINKS -->
                <div class="col-md-4 mb-4">

                    <h6 class="fw-bold mb-3">Quick Links</h6>

                    <ul class="list-unstyled">

                        <li class="mb-2">
                            <a asp-controller="Home" asp-action="Index"
                               class="text-decoration-none text-muted">
                                Home
                            </a>
                        </li>

                        <li class="mb-2">
                            <a asp-controller="Course" asp-action="Index"
                               class="text-decoration-none text-muted">
                                Courses
                            </a>
                        </li>

                        <li class="mb-2">
                            <a asp-controller="Assignment" asp-action="Index"
                               class="text-decoration-none text-muted">
                                Assignments
                            </a>
                        </li>

                        <li class="mb-2">
                            <a asp-controller="Home" asp-action="Privacy"
                               class="text-decoration-none text-muted">
                                Privacy Policy
                            </a>
                        </li>

                    </ul>

                </div>

                <!-- CONTACT + SOCIAL -->
                <div class="col-md-4 mb-4">

                    <h6 class="fw-bold mb-3">Contact</h6>

                    <p class="text-muted mb-1">📍 Dhaka, Bangladesh</p>
                    <p class="text-muted mb-1">📧 support@lms.com</p>
                    <p class="text-muted mb-3">📞 +880 1234 567890</p>

                    <div class="d-flex gap-2">

                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle">
                            <i class="bi bi-facebook"></i>
                        </a>

                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle">
                            <i class="bi bi-youtube"></i>
                        </a>

                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle">
                            <i class="bi bi-linkedin"></i>
                        </a>

                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle">
                            <i class="bi bi-github"></i>
                        </a>

                    </div>

                </div>

            </div>

            <hr class="border-secondary" />

            <!-- BOTTOM -->
            <div class="text-center text-muted small">

                © 2026 LMS Platform. All rights reserved.

            </div>

        </div>
    </footer>

    @* <footer class="border-top footer text-muted">
        <div class="container text-center text-capitalize">
            &copy; 2026 - LMS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
