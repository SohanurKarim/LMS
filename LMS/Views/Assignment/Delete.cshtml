@model LMS.Models.Assignment

@{
    ViewData["Title"] = "Delete Assignment";
}

<h2 class="mb-4 fw-bold text-danger">
    <i class="bi bi-exclamation-triangle-fill"></i> Delete Assignment
</h2>

<div class="card shadow-sm border-danger">

    <div class="card-body">

        <!-- HEADER WITH LOGO -->
        @* <div class="d-flex align-items-center mb-3">
            <img src="~/images/logo.png" width="40" height="40" class="me-2" />
            <h5 class="mb-0 text-danger">Assignment Deletion</h5>
        </div> *@

        <!-- WARNING BOX -->
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Warning!</strong>&nbsp;This assignment will be permanently removed.
        </div>

        <!-- DETAILS -->
        <dl class="row">

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-card-heading"></i> Title
            </dt>
            <dd class="col-sm-9 text-primary fw-semibold">
                @Model.Title
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-book"></i> Course
            </dt>
            <dd class="col-sm-9">
                <span class="badge bg-secondary">
                    @Model.Course?.Title
                </span>
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-star"></i> Max Points
            </dt>
            <dd class="col-sm-9">
                <span class="badge bg-info text-dark">
                    @Model.MaxPoints
                </span>
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-calendar-x"></i> Due Date
            </dt>
            <dd class="col-sm-9">
                <i class="bi bi-clock text-danger"></i>
                @Model.DueDate.ToString("dd MMM yyyy")
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-calendar-plus"></i> Created Date
            </dt>
            <dd class="col-sm-9">
                <i class="bi bi-clock text-success"></i>
                @Model.CreatedDate.ToString("dd MMM yyyy")
            </dd>

        </dl>

        <!-- ACTION BUTTONS -->
        <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">

            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger rounded-pill">
                <i class="bi bi-trash"></i> Confirm Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary rounded-pill">
                <i class="bi bi-arrow-left"></i> Cancel
            </a>

        </form>

    </div>
</div>