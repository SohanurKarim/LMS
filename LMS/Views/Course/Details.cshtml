@model LMS.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<h2 class="mb-4 fw-bold">
    <i class="bi bi-journal-text text-primary"></i> Course Details
</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-book"></i> Title
            </dt>
            <dd class="col-sm-9 text-primary fw-semibold">
                @Model.Title
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-card-text"></i> Description
            </dt>
            <dd class="col-sm-9">
                @Model.Description
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-award"></i> Credits
            </dt>
            <dd class="col-sm-9">
                <span class="badge bg-info text-dark">
                    @Model.Credits
                </span>
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-people"></i> Max Enrollment
            </dt>
            <dd class="col-sm-9">
                <span class="badge bg-warning text-dark">
                    @Model.MaxEnrollment
                </span>
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-calendar-check"></i> Start Date
            </dt>
            <dd class="col-sm-9">
                <i class="bi bi-clock text-success"></i>
                @Model.StartDate.ToString("dd MMM yyyy")
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-calendar-x"></i> End Date
            </dt>
            <dd class="col-sm-9">
                <i class="bi bi-clock text-danger"></i>
                @Model.EndDate.ToString("dd MMM yyyy")
            </dd>

            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-calendar-plus"></i> Created Date
            </dt>
            <dd class="col-sm-9">
                @Model.CreatedDate.ToString("dd MMM yyyy")
            </dd>

            <!-- STATUS -->
            <dt class="col-sm-3 fw-semibold">
                <i class="bi bi-activity"></i> Status
            </dt>
            <dd class="col-sm-9">
                @if (Model.EndDate >= DateTime.Now)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle"></i> Active
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        <i class="bi bi-x-circle"></i> Inactive
                    </span>
                }
            </dd>

        </dl>

        <!-- ACTION BUTTONS -->
        <div class="mt-4 d-flex gap-2">

            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-primary rounded-pill">
                <i class="bi bi-pencil"></i> Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary rounded-pill">
                <i class="bi bi-arrow-left"></i> Back
            </a>

        </div>

    </div>
</div>