@model IEnumerable<LMS.Models.Course>

@{
    ViewData["Title"] = "Courses";
}
@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Success',
            text: '@TempData["Success"]',
            timer: 2000,
            showConfirmButton: false
        });
    </script>
}

<h2 class="mb-4 fw-bold">
    <i class="bi bi-journal-bookmark-fill text-primary"></i> Courses List
</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="mb-3">
            <a class="btn btn-primary rounded-pill" asp-action="Create">
                <i class="bi bi-plus-circle"></i> Create Course
            </a>
        </div>

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th><i class="bi bi-book"></i> Title</th>
                    <th><i class="bi bi-card-text"></i> Description</th>
                    <th><i class="bi bi-person-badge"></i> Instructor</th>
                    <th><i class="bi bi-award"></i> Credits</th>
                    <th><i class="bi bi-people"></i> Max</th>
                    <th><i class="bi bi-calendar-event"></i> Start</th>
                    <th><i class="bi bi-calendar-x"></i> End</th>
                    <th><i class="bi bi-gear"></i> Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.EndDate < DateTime.Now ? "table-light" : "")">

                        <td class="fw-semibold text-primary">
                            @item.Title
                        </td>

                        <td>
                            @item.Description
                        </td>

                        <td>
                            <span class="badge bg-secondary">
                                @* <i class="bi bi-person"></i> @item.InstructorId *@
                                @* Here i can show instructor name *@
                                <i class="bi bi-person"></i>  @(item.Instructor?.UserName ?? "N/A")
                               
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-info text-dark">
                                @item.Credits
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-warning text-dark">
                                @item.MaxEnrollment
                            </span>
                        </td>

                        <td>
                            <i class="bi bi-calendar-check text-success"></i>
                            @item.StartDate.ToString("dd MMM yyyy")
                        </td>

                        <td>
                            <i class="bi bi-calendar-x text-danger"></i>
                            @item.EndDate.ToString("dd MMM yyyy")
                        </td>

                        <!-- ACTION BUTTONS -->
                        <td>
                            <a class="btn btn-sm btn-outline-success rounded-pill"
                               asp-action="Edit" asp-route-id="@item.Id">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <a class="btn btn-sm btn-outline-warning rounded-pill"
                               asp-action="Details" asp-route-id="@item.Id">
                                <i class="bi bi-eye"></i>
                            </a>

                            @* <a class="btn btn-sm btn-outline-danger rounded-pill"
                               asp-action="Delete" asp-route-id="@item.Id"
                               onclick="return confirm('Are you sure to delete this course?');">
                                <i class="bi bi-trash"></i>
                            </a> *@
                            <a href="javascript:void(0);"
                               class="btn btn-sm btn-outline-danger rounded-pill delete-btn"
                               data-id="@item.Id">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>

                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-exclamation-circle"></i> No courses available
            </div>
        }

    </div>
</div>
@section Scripts {
    <script>
        document.querySelectorAll(".delete-btn").forEach(button => {
            button.addEventListener("click", function () {

                let id = this.getAttribute("data-id");

                Swal.fire({
                    title: "Are you sure?",
                    text: "This course will be permanently deleted!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#6c757d",
                    confirmButtonText: "Yes, delete it!",
                    cancelButtonText: "Cancel"
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '/Course/Delete/' + id;
                    }
                });

            });
        });
    </script>
}