    <div class="container text-center">

        <div class="row">

            <div class="col-md-3">
                <h2 class="fw-bold text-primary">50+</h2>
                <p>Courses</p>
            </div>

            <div class="col-md-3">
                <h2 class="fw-bold text-success">1000+</h2>
                <p>Students</p>
            </div>

            <div class="col-md-3">
                <h2 class="fw-bold text-warning">200+</h2>
                <p>Assignments</p>
            </div>

            <div class="col-md-3">
                <h2 class="fw-bold text-danger">4.8★</h2>
                <p>Rating</p>
            </div>

        </div>

    </div>
</section>

