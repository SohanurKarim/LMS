                document.querySelectorAll(".approve-btn").forEach(btn => {
            btn.addEventListener("click", function () {

                let studentId = this.getAttribute("data-studentid");
                let assignmentId = this.getAttribute("data-assignmentid");

                Swal.fire({
                    title: 'Approve Assignment',
                    html:
                        '<input id="mark" class="swal2-input" placeholder="Enter Marks">' +
                        '<textarea id="feedback" class="swal2-textarea" placeholder="Feedback"></textarea>',
                    confirmButtonText: 'Approve',
                    showCancelButton: true,
                    preConfirm: () => {
                        return {
                            mark: document.getElementById('mark').value,
                            feedback: document.getElementById('feedback').value
                        }
                    }
                }).then((result) => {
                    if (result.isConfirmed) {

                        let form = document.createElement("form");
                        form.method = "post";
                        form.action = "/Assignment/Approve";

                        form.innerHTML =
                            `<input type="hidden" name="studentId" value="${studentId}" />
                             <input type="hidden" name="assignmentId" value="${assignmentId}" />
                             <input type="hidden" name="earnedMark" value="${result.value.mark}" />
                             <input type="hidden" name="feedback" value="${result.value.feedback}" />`;

                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            });
        });
    </script>
