@using Microsoft.AspNetCore.Identity
@inject UserManager<User> userManager  // Here we inject the UserManager to get the user's information, such as their name, to display in the navbar
@inject SignInManager<User> SignInManager // Here we inject the SignInManager to check if the user is signed in

<ul class="navbar-nav ms-auto">
    @if (SignInManager.IsSignedIn(User))
    {
        // If the user is signed in, we get their information using the UserManager and display their name in the navbar. If we can't find the user for some reason, we default to displaying "User".
        var user = userManager.Users.FirstOrDefault(u => u.Email == userManager.GetUserName(User));
        string name = user != null ? user.Name : "User";
        string email = user != null ? user.Email : "User";

        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="ChangePassword"><i class="fa-solid fa-key mx-2"></i>Change Password</a>
        </li>    


        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Profile"><i class="fa-solid fa-user mx-2"></i>@name</a>
        </li>
        
        <li class="nav-item">
            @* <form id="logoutForm" class="form-inline" asp-area="" asp-controller="Login" asp-action="Logout" method="post">
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form> *@

            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Logout"><i class="fa-solid fa-xl mx-2 fa-arrow-right-from-bracket"></i>Logout</a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Register"><i class="fa-solid fa-person fa-xl mx-2"></i>Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Login"><i class="fa-solid fa-user mx-2"></i>Login</a>
        </li>
    }
</ul>
